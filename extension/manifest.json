{
  "manifest_version": 3,
  "name": "YT Music Local Bridge",
  "version": "1.0",
  "permissions": ["tabs"],
  "host_permissions": [
    "https://music.youtube.com/*",
    "https://music.monse.co.id/*",
    "http://localhost:4786/*",
    "http://127.0.0.1:4786/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://music.youtube.com/*"],
      "js": ["content.js"]
    }
  ]
}
